# llm-homelab-training - Local environment template
# Copy to `.env` and adjust values for your host.
# Do not commit `.env`.
#
# Scope:
# - Training stack (`docker/compose.yaml`)
# - Serving stack (`docker/compose.serve.yaml`)
#
# Notes:
# - Most values have safe defaults in Compose and are therefore optional.
# - This file exists to make local host-specific overrides explicit and reproducible.
# - No secrets or tokens belong in this file.

# Docker Compose project names
# Compose can use this for naming containers/networks/volumes.
COMPOSE_PROJECT_NAME=llm-homelab-training

# GPU visibility
# Use "all" or a comma-separated GPU list such as "0" or "0,1".
NVIDIA_VISIBLE_DEVICES=all
CUDA_VISIBLE_DEVICES=0

# NVIDIA runtime capabilities
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Hugging Face cache paths inside the container
HF_HOME=/workspace/.cache/huggingface
HF_DATASETS_CACHE=/workspace/.cache/huggingface/datasets
TRANSFORMERS_CACHE=/workspace/.cache/huggingface/transformers

# Training / evaluation defaults
# Current project baseline model for LoRA training and evaluation.
BASE_MODEL=facebook/opt-2.7b
PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:128

# Serving defaults
# Port exposed by `docker/compose.serve.yaml`
SERVE_PORT=8901
SERVE_HOST=0.0.0.0

# Pointer file used by serving to resolve the currently promoted adapter
LATEST_OK_POINTER=/workspace/data/runs/LATEST_OK_ADAPTER_ID

# Health endpoint path for serving
HEALTH_PATH=/health

# Optional logging / local access
TENSORBOARD_PORT=6006

# Optional notes for operators
# - Training targets read configs and datasets primarily from `Makefile`.
# - Current defaults in the repository:
#   - train config: `configs/train_lora_3b_k80_short.yaml`
#   - train dataset: `data/datasets/train.jsonl`
# - Serving always loads the adapter pointed to by `LATEST_OK_POINTER`.

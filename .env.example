# llm-homelab-training - Local environment template
# Copy to `.env` and adjust values for your host.
# Do not commit `.env`.

# Docker compose
COMPOSE_PROJECT_NAME=llm-homelab-training

# GPU visibility (set to "all" or specific IDs like "0")
NVIDIA_VISIBLE_DEVICES=all
CUDA_VISIBLE_DEVICES=0

# NVIDIA runtime capabilities
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Hugging Face cache locations (inside container paths can be mapped if needed)
HF_HOME=/workspace/.cache/huggingface
HF_DATASETS_CACHE=/workspace/.cache/huggingface/datasets
TRANSFORMERS_CACHE=/workspace/.cache/huggingface/transformers

# Optional: model source (public model name; no token here)
BASE_MODEL_NAME=facebook/opt-2.7b

# Optional: training defaults
TRAIN_CONFIG=/workspace/configs/train_lora_3b_k80.yaml
TRAIN_DATA_PATH=/workspace/data/datasets/train.jsonl

# Optional: logging
TENSORBOARD_PORT=6006
